# variables fall back to the defaults in src/config/config.py.
# CLI flags (where available) take precedence over these.

RAG_DB_PATH=data/output/rag_demo.db
RAG_COLLECTION=demo_collection
RAG_MODEL_NAME=intfloat/e5-large-v2
RAG_DEVICE=cuda
RAG_TRUST_REMOTE_CODE=true
RAG_DATA_DIR=data/input
